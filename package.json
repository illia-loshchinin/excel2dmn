{
  "name": "excel2dmn",
  "version": "0.1.2",
  "description": "Convert pre-formatted Excel decision tables into Camunda 7 DMN 1.3 files (and back).",
  "type": "module",
  "license": "MIT",
  "author": "Illia",
  "keywords": [
    "dmn",
    "camunda",
    "camunda7",
    "excel",
    "xlsx",
    "decision-table",
    "dmn-1.3",
    "feel",
    "converter"
  ],
  "homepage": "https://github.com/illia-loshchinin/excel2dmn#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/illia-loshchinin/excel2dmn.git"
  },
  "bugs": {
    "url": "https://github.com/illia-loshchinin/excel2dmn/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "excel2dmn": "bin/excel2dmn.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "bin",
    "schema",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "convert": "node bin/excel2dmn.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "licenses": "license-checker --production --summary",
    "licenses:check": "license-checker --production --onlyAllow 'MIT;MIT*;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;0BSD;Unlicense;CC0-1.0;(MIT OR GPL-3.0-or-later);(MIT AND Zlib);(WTFPL OR MIT)' --excludePackages 'excel2dmn@0.1.0;buffers@0.1.1'",
    "licenses:notices": "license-checker --production --customPath .license-format.json --out THIRD-PARTY-NOTICES.txt",
    "prepublishOnly": "npm run lint && npm test"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^12.1.0",
    "dmn-moddle": "^12.0.1",
    "exceljs": "^4.4.0",
    "feelin": "^7.0.1"
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "license-checker": "^25.0.1",
    "prettier": "^3.3.3",
    "vitest": "^2.1.4"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
